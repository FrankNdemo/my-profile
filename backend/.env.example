DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_TIME_ZONE=Africa/Nairobi

# Preferred for long-lived Django connections: use the direct Supabase Postgres connection string.
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres?sslmode=require

# Or use the explicit fields below instead of DATABASE_URL.
# SUPABASE_DB_NAME=postgres
# SUPABASE_DB_USER=postgres
# SUPABASE_DB_PASSWORD=your-password
# SUPABASE_DB_HOST=aws-0-eu-west-1.pooler.supabase.com
# SUPABASE_DB_PORT=6543
# SUPABASE_DB_SSLMODE=require

# Keep this at 60 for a direct connection. If you use Supabase's transaction pooler on port 6543, set it to 0.
DB_CONN_MAX_AGE=60
PORTFOLIO_ALLOWED_ORIGINS=http://127.0.0.1:8080,http://localhost:8080
